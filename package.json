{
  "name": "miriels-deck-of-encounters",
  "version": "0.26.0",
  "private": true,
  "description": "Statische Browser-App mit lokalem Node.js-Entwicklungsserver und automatisierten Tests.",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "npm run test:unit && npm run test:browser",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:browser": "playwright test",
    "test:browser:headed": "playwright test --headed",
    "test:browser:ui": "playwright test --ui",
    "test:browser:install": "playwright install chromium",
    "test:report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module"
}
